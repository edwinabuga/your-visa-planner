# .env.local (copy this file to .env.local and fill in values)
NEXT_PUBLIC_WHATSAPP_NUMBER=        # WhatsApp number (format: 254XXXXXXXXX)
NEXT_PUBLIC_SITE_URL=               # Production URL once deployed
GMAIL_USER=                         # Gmail address for sending emails (e.g. edwinabuga@gmail.com)
GMAIL_APP_PASSWORD=                 # Gmail App Password (generate at https://myaccount.google.com/apppasswords — requires 2FA)
RECIPIENT_EMAIL=                    # Email address to receive form submissions
